[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
CN = testnet.test
O = Interledger
C = US

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = testnet.test
DNS.2 = api.testnet.test
DNS.3 = auth.testnet.test
DNS.4 = rafiki-backend.testnet.test
DNS.5 = rafiki-frontend.testnet.test
DNS.6 = rafiki-card-service.testnet.test
DNS.7 = mockgatehub.testnet.test
DNS.8 = boutique.testnet.test
DNS.9 = api.boutique.testnet.test
DNS.10 = localhost
IP.1 = 127.0.0.1