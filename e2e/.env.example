TEST_BASE_URL=https://testnet.test
# Optional: override the Postgres connection used by the email-verification test helper.
# Defaults to the local dev DB (port 15434, wallet_backend credentials).
# TEST_DB_URL=postgres://wallet_backend:wallet_backend@localhost:15434/wallet_backend
# Optional: override the wallet backend URL used for email verification (direct HTTP, no TLS).
# Defaults to the local dev backend on port 3003.
# TEST_API_URL=http://localhost:3003
# Set to true only if your local cert trust is not configured (e.g. self-signed cert not trusted by OS).
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false
