{
  "name": "@benchmark/open-payments",
  "version": "1.0.0",
  "description": "Open Payments partial-payment throughput benchmark for Interledger TestNet",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "op-benchmark": "dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "bench": "node dist/cli.js",
    "provision": "node dist/cli.js provision",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@interledger/open-payments": "^7.3.0",
    "@playwright/test": "^1.56.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.1",
    "@types/pg": "^8.15.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
