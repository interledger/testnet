{
  "preset": "ts-jest",
  "clearMocks": true,
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/tests"],
  "modulePathIgnorePatterns": ["<rootDir>/dist/"],
  "moduleNameMapper": {
    "@/tests/(.*)": "<rootDir>/tests/$1",
    "@/(.*)": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/index.ts",
    "!src/cli.ts",
    "!src/types.ts"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 80,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  }
}
